{
    "name": "Rust Dev Container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "workspaceFolder": "/home/vscode/app",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/app,type=bind",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer"
            ]
        }
    },
    "postCreateCommand": ""
}